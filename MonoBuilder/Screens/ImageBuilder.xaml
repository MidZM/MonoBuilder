<Window
    x:Class="MonoBuilder.Screens.ScreenUtils.ImageBuilder"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonoBuilder.Screens.ScreenUtils"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:MonoBuilder.Utils"
    Title="MonoBuilder | Image Builder"
    Width="825"
    Height="600"
    d:DataContext="{d:DesignInstance Type=local:ImageBuilder}"
    SizeChanged="Window_SizeChanged"
    Style="{StaticResource WindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid x:Name="MainContent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="225" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Image
            x:Name="ImgPreview"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="10"
            Stretch="Uniform" />
        <Grid
            x:Name="EditingContent"
            Grid.Row="1"
            MaxWidth="1250">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="250" />
            </Grid.ColumnDefinitions>
            <Grid
                Grid.Row="1"
                MaxWidth="1250"
                Margin="10,0,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TabControl
                    x:Name="ImageFilterTabs"
                    Grid.Row="0"
                    Height="40"
                    Margin="3,5,3,0"
                    Background="#111111"
                    BorderBrush="Maroon"
                    DockPanel.Dock="Top"
                    SelectionChanged="ImageFilterTabs_SelectionChanged" />
                <DataGrid
                    x:Name="ImagesDataGrid"
                    Grid.Row="1"
                    Width="550"
                    MaxWidth="970"
                    Margin="5,0,5,5"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserResizeRows="False"
                    DockPanel.Dock="Top"
                    HeadersVisibility="Column"
                    HorizontalScrollBarVisibility="Disabled"
                    IsReadOnly="True"
                    MouseDoubleClick="ImagesDataGrid_MouseDoubleClick"
                    PreviewMouseLeftButtonDown="ImagesDataGrid_PreviewMouseLeftButtonDown"
                    PreviewMouseWheel="ImagesDataGrid_PreviewMouseWheel"
                    SelectedCellsChanged="ImagesDataGrid_SelectedCellsChanged"
                    Tag="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem
                                x:Name="ContextMoveImage"
                                Header="Move Character"
                                ItemsSource="{Binding PlacementTarget.Tag.AvailableFiles, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                MenuItem.Click="ContextMoveImage_Click"
                                SubmenuOpened="ContextMoveImage_SubmenuOpened" />
                            <Separator />
                            <MenuItem
                                x:Name="ContextAddImage"
                                Click="BtnAddImage_Click"
                                Header="Add Character" />
                            <MenuItem
                                x:Name="ContextModifyImage"
                                Click="BtnModifyImage_Click"
                                Header="Modify Character" />
                            <MenuItem
                                x:Name="ContextRemoveImage"
                                Click="BtnRemoveImage_Click"
                                Header="Remove Character" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="1*"
                            MinWidth="80"
                            Binding="{Binding EntityID}"
                            Header="Image ID" />
                        <DataGridTextColumn
                            Width="2*"
                            MinWidth="80"
                            Binding="{Binding Name}"
                            Header="Name" />
                        <DataGridTextColumn
                            Width="4*"
                            MinWidth="80"
                            Binding="{Binding Path}"
                            Header="Path (Directory)" />
                        <DataGridTextColumn
                            Width="1*"
                            MinWidth="80"
                            Binding="{Binding IsSynced}"
                            Header="Synced" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
            <Grid
                x:Name="ButtonContainer"
                Grid.Row="1"
                Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Button
                    x:Name="BtnAddImage"
                    Grid.Row="0"
                    Width="240"
                    Margin="5"
                    Padding="2"
                    HorizontalAlignment="Center"
                    Click="BtnAddImage_Click"
                    Content="Add Image Assets"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnModifyImage"
                    Grid.Row="1"
                    Width="240"
                    Margin="5"
                    Padding="2"
                    HorizontalAlignment="Center"
                    Click="BtnModifyImage_Click"
                    Content="Modify Image Assets"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnRemoveImage"
                    Grid.Row="2"
                    Width="240"
                    Margin="5"
                    Padding="2"
                    HorizontalAlignment="Center"
                    Click="BtnRemoveImage_Click"
                    Content="Remove Image Assets"
                    Style="{StaticResource ErrorButton}" />
                <Button
                    x:Name="BtnSyncImage"
                    Grid.Row="4"
                    Width="240"
                    Margin="5"
                    Padding="2"
                    HorizontalAlignment="Center"
                    Click="BtnSyncImage_Click"
                    Content="Sync Image Assets"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnImportImage"
                    Grid.Row="5"
                    Width="240"
                    Margin="5"
                    Padding="2"
                    HorizontalAlignment="Center"
                    Click="BtnImportImage_Click"
                    Content="Import Image Assets"
                    Style="{StaticResource DefaultButton}" />
            </Grid>
        </Grid>
        <Label
            x:Name="ChangesMadeLabel"
            Grid.Row="2"
            Grid.Column="1"
            HorizontalAlignment="Left"
            Content="Changes Made..."
            Visibility="Collapsed" />
        <Button
            x:Name="BtnClose"
            Grid.Row="2"
            Grid.Column="1"
            Width="100"
            Padding="2"
            HorizontalAlignment="Right"
            Click="BtnClose_Click"
            Content="Close"
            Style="{StaticResource DefaultButton}" />
    </Grid>
</Window>
