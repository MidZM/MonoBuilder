<Window
    x:Class="MonoBuilder.Screens.ScriptBuilder"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonoBuilder.Screens"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:MonoBuilder.Utils"
    Title="MonoBuilder | Script Builder"
    Width="1400"
    Height="800"
    d:DataContext="{d:DesignInstance Type=local:ScriptBuilder}"
    PreviewMouseDown="Window_PreviewMouseDown"
    Style="{StaticResource WindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Window.Resources>
        <Style
            x:Key="ToolBarButton"
            BasedOn="{StaticResource DefaultButton}"
            TargetType="Button">
            <Setter Property="Padding" Value="5" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Height" Value="40" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Gray" />
            <Setter Property="Background" Value="#222222" />
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="MainBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                            <ContentPresenter
                                x:Name="Content"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Cursor="{TemplateBinding Cursor}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <!-- <Setter TargetName="MainBorder" Property="Background" Value="DarkGray" /> -->
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#555555" />
                                <Setter Property="Foreground" Value="#999999" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="DarkGray" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <utils:RectConverter x:Key="RectConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Window.CommandBindings>
        <CommandBinding Command="utils:Helpers.LoadLabel" Executed="LoadCommand_Executed" />
        <CommandBinding Command="utils:Helpers.SaveLabel" Executed="SaveCommand_Executed" />
        <CommandBinding Command="utils:Helpers.ResetInputLabel" Executed="ResetInputLabel_Executed" />
        <CommandBinding Command="utils:Helpers.ConvertScript" Executed="ConvertScriptCommand_Executed" />
    </Window.CommandBindings>
    <Grid x:Name="MainContent">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <TextBox
            x:Name="ScriptLabel"
            Grid.Row="0"
            Margin="10"
            Background="#444444"
            Foreground="#FFFFFF"
            Style="{StaticResource DefaultTextBox}"
            Tag="Enter Label Name..."
            TextChanged="ScriptLabel_TextChanged" />
        <Border
            x:Name="ScriptInputBorder"
            Grid.Row="1"
            Margin="10"
            Background="#444444"
            BorderBrush="Maroon"
            BorderThickness="1"
            CornerRadius="8">
            <DockPanel
                x:Name="ScriptInputContainer"
                Grid.Row="1"
                Background="#444444">
                <DockPanel.Clip>
                    <RectangleGeometry RadiusX="8" RadiusY="8">
                        <RectangleGeometry.Rect>
                            <MultiBinding Converter="{StaticResource RectConverter}">
                                <Binding ElementName="ScriptInputContainer" Path="ActualWidth" />
                                <Binding ElementName="ScriptInputContainer" Path="ActualHeight" />
                            </MultiBinding>
                        </RectangleGeometry.Rect>
                    </RectangleGeometry>
                </DockPanel.Clip>

                <ToolBarTray Background="#222222" DockPanel.Dock="Top">
                    <ToolBar Background="#222222">
                        <Button
                            x:Name="BtnReset"
                            Command="utils:Helpers.ResetInputLabel"
                            CommandTarget="{Binding ElementName=RawScriptInput}"
                            Content="Reset"
                            IsEnabled="{Binding ShouldEnableReset.Value}"
                            Style="{StaticResource ToolBarButton}"
                            ToolTip="Alt+R" />
                        <Button
                            Command="utils:Helpers.LoadLabel"
                            CommandTarget="{Binding ElementName=RawScriptInput}"
                            Content="Load Label"
                            Style="{StaticResource ToolBarButton}" />
                        <Button
                            Command="utils:Helpers.SaveLabel"
                            CommandTarget="{Binding ElementName=RawScriptInput}"
                            Content="Save Label"
                            IsEnabled="{Binding ShouldEnableConvert.Value}"
                            Style="{StaticResource ToolBarButton}" />
                        <Separator Background="Maroon" />
                        <Button
                            x:Name="BtnBold"
                            Width="30"
                            Command="utils:Helpers.ToggleBold"
                            CommandTarget="{Binding ElementName=RawScriptInput}"
                            Content="B"
                            FontFamily="Times New Roman"
                            FontWeight="Black"
                            Style="{StaticResource ToolBarButton}"
                            ToolTip="Ctrl+B" />
                        <Button
                            x:Name="BtnItalic"
                            Width="30"
                            Command="utils:Helpers.ToggleItalic"
                            CommandTarget="{Binding ElementName=RawScriptInput}"
                            Content=" I "
                            FontFamily="Times New Roman"
                            FontStyle="Italic"
                            Style="{StaticResource ToolBarButton}"
                            ToolTip="Ctrl+I" />
                        <!-- <Button
                            x:Name="BtnUnderline"
                            Width="30"
                            Click="BtnUnderline_Click"
                            Command="EditingCommands.ToggleUnderline"
                            CommandTarget="{Binding ElementName=ScriptInput}"
                            Style="{StaticResource ToolBarButton}"
                            ToolTip="Ctrl+U">
                            <TextBlock
                                FontFamily="Times New Roman"
                                FontWeight="Bold"
                                Text="U"
                                TextDecorations="Underline" />
                        </Button>-->
                        <Button
                            x:Name="BtnBig"
                            Command="utils:Helpers.ToggleBig"
                            CommandTarget="{Binding ElementName=RawScriptInput}"
                            Content="Big"
                            FontSize="16"
                            FontWeight="Bold"
                            Style="{StaticResource ToolBarButton}"
                            ToolTip="Alt+B" />
                        <Button
                            x:Name="BtnSmall"
                            Command="utils:Helpers.ToggleSmall"
                            CommandTarget="{Binding ElementName=RawScriptInput}"
                            Content="Small"
                            FontSize="9"
                            FontWeight="Bold"
                            Style="{StaticResource ToolBarButton}"
                            ToolTip="Alt+S" />
                        <Separator Background="Maroon" />
                        <Button
                            x:Name="BtnIndent"
                            Command="utils:Helpers.IndentForward"
                            CommandTarget="{Binding ElementName=RawScriptInput}"
                            Content="↦ Indent"
                            FontWeight="Bold"
                            Style="{StaticResource ToolBarButton}"
                            ToolTip="Ctrl+]" />
                        <Button
                            x:Name="BtnUnindent"
                            Command="utils:Helpers.IndentBackward"
                            CommandTarget="{Binding ElementName=RawScriptInput}"
                            Content="↤ Unindent"
                            FontWeight="Bold"
                            Style="{StaticResource ToolBarButton}"
                            ToolTip="Ctrl+[" />
                        <Separator Background="Maroon" />
                        <Menu Margin="10" VerticalAlignment="Center">
                            <Menu.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#555555" />
                                <Style TargetType="Menu">
                                    <Setter Property="BorderBrush" Value="#111111" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="Background" Value="#333333" />
                                </Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="BorderBrush" Value="#333333" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="Background" Value="#333333" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Padding" Value="5" />
                                    <Setter Property="Cursor" Value="Hand" />
                                </Style>
                            </Menu.Resources>
                            <MenuItem Header="Effects" Icon=" ▼">
                                <MenuItem Header="Special">
                                    <MenuItem Click="CompleteAction" Header="pause" />
                                    <MenuItem Click="CompleteAction" Header="speed" />
                                </MenuItem>

                                <Separator Background="Maroon" />

                                <MenuItem Header="Shake">
                                    <MenuItem Click="CompleteAction" Header="shake" />
                                    <MenuItem Click="CompleteAction" Header="shake-hard" />
                                    <MenuItem Click="CompleteAction" Header="shake-slow" />
                                    <MenuItem Click="CompleteAction" Header="shake-little" />
                                    <MenuItem Click="CompleteAction" Header="shake-horizontal" />
                                    <MenuItem Click="CompleteAction" Header="shake-vertical" />
                                </MenuItem>

                                <MenuItem Header="Wave">
                                    <MenuItem Click="CompleteAction" Header="wave" />
                                    <MenuItem Click="CompleteAction" Header="wave-slow" />
                                    <MenuItem Click="CompleteAction" Header="wave-fast" />
                                </MenuItem>

                                <MenuItem Header="Reveal">
                                    <MenuItem Click="CompleteAction" Header="fade" />
                                    <MenuItem Click="CompleteAction" Header="fade-slow" />
                                    <MenuItem Click="CompleteAction" Header="blur" />
                                    <MenuItem Click="CompleteAction" Header="scale" />
                                    <MenuItem Click="CompleteAction" Header="scale-bounce" />
                                    <MenuItem Click="CompleteAction" Header="slide-up" />
                                    <MenuItem Click="CompleteAction" Header="slide-down" />
                                </MenuItem>

                                <MenuItem Header="Glitch">
                                    <MenuItem Click="CompleteAction" Header="glitch" />
                                    <MenuItem Click="CompleteAction" Header="glitch-hard" />
                                    <MenuItem Click="CompleteAction" Header="glitch-slow" />
                                </MenuItem>

                                <MenuItem Header="Emphasis">
                                    <MenuItem Click="CompleteAction" Header="impact" />
                                </MenuItem>

                                <MenuItem Header="Reveal Style">
                                    <MenuItem Click="CompleteAction" Header="redacted" />
                                    <MenuItem Click="CompleteAction" Header="invisible-ink" />
                                    <MenuItem Click="CompleteAction" Header="handwriting" />
                                    <MenuItem Click="CompleteAction" Header="strike" />
                                    <MenuItem Click="CompleteAction" Header="flicker" />
                                </MenuItem>

                                <MenuItem Header="Emotion">
                                    <MenuItem Click="CompleteAction" Header="angry" />
                                    <MenuItem Click="CompleteAction" Header="scared" />
                                    <MenuItem Click="CompleteAction" Header="happy" />
                                    <MenuItem Click="CompleteAction" Header="sad" />
                                    <MenuItem Click="CompleteAction" Header="mysterious" />
                                    <MenuItem Click="CompleteAction" Header="excited" />
                                    <MenuItem Click="CompleteAction" Header="whisper" />
                                    <MenuItem Click="CompleteAction" Header="shout" />
                                    <MenuItem Click="CompleteAction" Header="dizzy" />
                                    <MenuItem Click="CompleteAction" Header="dreamy" />
                                    <MenuItem Click="CompleteAction" Header="robotic" />
                                    <MenuItem Click="CompleteAction" Header="static" />
                                </MenuItem>

                                <MenuItem Header="Color">
                                    <MenuItem Click="CompleteAction" Header="rainbow" />
                                    <MenuItem Click="CompleteAction" Header="glow" />
                                </MenuItem>
                            </MenuItem>
                        </Menu>
                    </ToolBar>
                </ToolBarTray>
                <avalonEdit:TextEditor
                    x:Name="RawScriptInput"
                    Margin="0,5,0,0"
                    Padding="5"
                    Background="#222222"
                    BorderThickness="0"
                    DockPanel.Dock="Bottom"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="DarkOrange"
                    PreviewKeyDown="RawScriptInput_PreviewKeyDown"
                    ShowLineNumbers="True"
                    TextChanged="RawScriptInput_TextChanged">
                    <avalonEdit:TextEditor.CommandBindings>
                        <CommandBinding Command="utils:Helpers.ToggleBold" Executed="BoldCommand_Executed" />
                        <CommandBinding Command="utils:Helpers.ToggleItalic" Executed="ItalicCommand_Executed" />

                        <CommandBinding Command="utils:Helpers.ToggleBig" Executed="BigCommand_Executed" />
                        <CommandBinding Command="utils:Helpers.ToggleSmall" Executed="SmallCommand_Executed" />

                        <CommandBinding Command="utils:Helpers.IndentForward" Executed="IndentForwardCommand_Executed" />
                        <CommandBinding Command="utils:Helpers.IndentBackward" Executed="IndentBackwardCommand_Executed" />
                    </avalonEdit:TextEditor.CommandBindings>
                </avalonEdit:TextEditor>
            </DockPanel>
        </Border>
        <Popup
            x:Name="ActionPopup"
            Grid.Row="1"
            Grid.Column="1"
            AllowsTransparency="True"
            DockPanel.Dock="Bottom"
            Placement="Relative"
            PopupAnimation="Fade"
            StaysOpen="True">
            <Border
                Background="#111111"
                BorderBrush="Maroon"
                BorderThickness="1">
                <ListBox
                    x:Name="ActionListBox"
                    MaxHeight="300"
                    DisplayMemberPath="DisplayName"
                    KeyDown="ActionListBox_KeyDown"
                    MouseUp="ActionListBox_MouseUp"
                    SelectionChanged="ActionListBox_SelectionChanged" />
            </Border>
        </Popup>
        <Button
            x:Name="BtnConvert"
            Grid.Row="2"
            Margin="10"
            Padding="5"
            Command="utils:Helpers.ConvertScript"
            CommandTarget="{Binding ElementName=ScriptInput}"
            Content="Convert to Engine Script"
            IsEnabled="{Binding ShouldEnableConvert.Value}"
            Style="{StaticResource DefaultButton}"
            ToolTip="Convert raw script data into a working engine label. (Alt+C)" />
    </Grid>
</Window>
