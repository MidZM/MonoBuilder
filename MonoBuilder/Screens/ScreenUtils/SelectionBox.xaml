<Window
    x:Class="MonoBuilder.Screens.ScreenUtils.SelectionBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonoBuilder.Screens.ScreenUtils"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title=""
    Width="450"
    MinWidth="200"
    MaxWidth="600"
    Padding="25"
    Background="#232323"
    Closing="Window_Closing"
    ResizeMode="NoResize"
    Topmost="True"
    mc:Ignorable="d">
    <DockPanel x:Name="MainContainer">
        <Grid
            x:Name="ContentContainer"
            Margin="0,15,0,10"
            DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="86" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Image
                x:Name="TypeImage"
                Grid.RowSpan="2"
                Grid.Column="0"
                Width="30"
                Height="30"
                Margin="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
            <TextBlock
                x:Name="TextContent"
                Grid.Column="1"
                Width="Auto"
                Height="Auto"
                Margin="0,0,0,5"
                Padding="0,0,25,0"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="#FFFFFF"
                Text="Test Text"
                TextWrapping="Wrap" />
            <ComboBox
                x:Name="SelectionOptions"
                Grid.Row="1"
                Grid.Column="1"
                Width="Auto"
                Height="Auto"
                Margin="0,5,25,5"
                VerticalAlignment="Center"
                FontSize="12"
                Style="{StaticResource DefaultComboBox}" />
        </Grid>
        <Grid
            x:Name="ButtonContainer"
            Height="50"
            DockPanel.Dock="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="Select"
                Grid.Column="0"
                Click="Select_Click"
                Content="Select"
                Style="{StaticResource DefaultButton}" />
            <Button
                x:Name="Cancel"
                Grid.Column="1"
                Click="Cancel_Click"
                Content="Cancel"
                Style="{StaticResource ErrorButton}" />
        </Grid>
    </DockPanel>
</Window>
