<Window
    x:Class="MonoBuilder.Screens.ScreenUtils.DialogBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonoBuilder.Screens.ScreenUtils"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:MonoBuilder.Utils"
    Title=""
    Width="450"
    MinWidth="200"
    MaxWidth="600"
    Padding="25"
    Background="#232323"
    ResizeMode="NoResize"
    Topmost="True"
    mc:Ignorable="d">
    <DockPanel x:Name="MainContainer">
        <Grid
            x:Name="ContentContainer"
            Margin="0,15,0,10"
            DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="86" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Image
                x:Name="TypeImage"
                Grid.Column="0"
                Width="30"
                Height="30"
                Margin="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
            <TextBlock
                x:Name="TextContent"
                Grid.Column="1"
                Width="Auto"
                Height="Auto"
                Padding="0,0,25,0"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="#FFFFFF"
                Text="Test Text"
                TextWrapping="Wrap" />
        </Grid>
        <Grid
            x:Name="ButtonContainer"
            Height="50"
            DockPanel.Dock="Bottom" />
    </DockPanel>
</Window>
