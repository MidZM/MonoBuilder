<Window
    x:Class="MonoBuilder.Screens.ScreenUtils.LoadScripts"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonoBuilder.Screens.ScreenUtils"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MonoBuilder | Load a Script"
    Width="1000"
    Height="600"
    d:DataContext="{d:DesignInstance Type=local:LoadScripts}"
    Style="{StaticResource WindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid x:Name="MainContent" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <TabControl
            x:Name="MainTabControl"
            Grid.Row="0"
            Grid.Column="0"
            SelectionChanged="MainTabControl_SelectionChanged">
            <TabItem Background="MistyRose" Header="Unsynced">
                <Grid Background="#222222">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="50" />
                    </Grid.RowDefinitions>
                    <DataGrid
                        x:Name="DGUnsynced"
                        Grid.Row="0"
                        Width="344"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserResizeRows="False"
                        HeadersVisibility="Column"
                        HorizontalScrollBarVisibility="Disabled"
                        IsReadOnly="True"
                        ItemsSource="{Binding UnsyncedLabels}"
                        MouseDoubleClick="DG_MouseDoubleClick"
                        SelectedCellsChanged="DG_SelectedCellsChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding FileKey}"
                                Header="File" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Name}"
                                Header="Label" />
                            <DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding WordCount}"
                                Header="Words" />
                            <DataGridCheckBoxColumn
                                Width="Auto"
                                Binding="{Binding Synced}"
                                Header="Synced" />
                            <DataGridCheckBoxColumn
                                Width="Auto"
                                Binding="{Binding InScript}"
                                Header="In Script" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button
                        x:Name="BtnSync"
                        Grid.Row="1"
                        Padding="5"
                        Click="BtnSync_Click"
                        Content="Sync Labels"
                        IsEnabled="{Binding UnsyncedLabelsExist.Value}"
                        Style="{StaticResource DefaultButton}" />
                </Grid>
            </TabItem>

            <TabItem Background="LightBlue" Header="Synced">
                <Grid Background="#222222">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="50" />
                    </Grid.RowDefinitions>
                    <DataGrid
                        x:Name="DGSynced"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserResizeRows="False"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        ItemsSource="{Binding SyncedLabels}"
                        MouseDoubleClick="DG_MouseDoubleClick"
                        SelectedCellsChanged="DG_SelectedCellsChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding FileKey}"
                                Header="File" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Name}"
                                Header="Label" />
                            <DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding WordCount}"
                                Header="Words" />
                            <DataGridCheckBoxColumn
                                Width="Auto"
                                Binding="{Binding Synced}"
                                Header="Synced" />
                            <DataGridCheckBoxColumn
                                Width="Auto"
                                Binding="{Binding InScript}"
                                Header="In Script" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="BtnMergeWithScript"
                            Grid.Column="0"
                            Padding="5"
                            Click="BtnMergeWithScript_Click"
                            Content="Merge With Script"
                            IsEnabled="{Binding SyncedLabelSelected.Value}"
                            Style="{StaticResource DefaultButton}" />
                        <Button
                            x:Name="BtnRemove"
                            Grid.Column="1"
                            Padding="5"
                            Click="BtnRemove_Click"
                            Content="Remove"
                            IsEnabled="{Binding SyncedLabelSelected.Value}"
                            Style="{StaticResource ErrorButton}" />
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
        <RichTextBox
            x:Name="PreviewBox"
            Grid.Row="0"
            Grid.Column="1"
            IsReadOnly="True" />
        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="BtnImport"
                Grid.Column="0"
                Click="BtnImport_Click"
                Content="Import Labels"
                Style="{StaticResource DefaultButton}" />
            <Label
                x:Name="ChangesMadeLabel"
                Grid.Column="1"
                Margin="5"
                VerticalAlignment="Center"
                Content="Script File Changed"
                Visibility="Collapsed" />
            <Button
                x:Name="BtnLoad"
                Grid.Column="3"
                Click="BtnLoad_Click"
                Content="Load"
                IsEnabled="{Binding SyncedLabelSelected.Value}"
                Style="{StaticResource DefaultButton}" />
            <Button
                x:Name="BtnClose"
                Grid.Column="4"
                Click="BtnClose_Click"
                Content="Close"
                IsCancel="True"
                Style="{StaticResource ErrorButton}" />
        </Grid>
    </Grid>
</Window>
