<Window
    x:Class="MonoBuilder.Screens.ScreenUtils.AddModifyCharacter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:colorpicker="clr-namespace:ColorPicker;assembly=ColorPicker"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonoBuilder.Screens.ScreenUtils"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:MonoBuilder.Utils"
    Title="Add Characters"
    Width="1000"
    Height="235"
    MaxHeight="505"
    d:DataContext="{d:DesignInstance Type=local:AddModifyCharacter}"
    Style="{StaticResource WindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Window.Resources>
        <utils:HexToBrushConverter x:Key="HexToBrushConverter" />
        <utils:ShouldLightenText x:Key="ShouldLightenText" />

        <Style
            x:Key="ColorButton"
            BasedOn="{StaticResource DefaultButton}"
            TargetType="Button">
            <Setter Property="Background" Value="{Binding Content, RelativeSource={RelativeSource Self}, Converter={StaticResource HexToBrushConverter}}" />
            <Setter Property="Foreground" Value="{Binding Content, RelativeSource={RelativeSource Self}, Converter={StaticResource ShouldLightenText}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Cursor="Hand" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="MainContainer" Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="125" />
            <ColumnDefinition Width="125" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Label
            x:Name="EditingType"
            Grid.Row="0"
            Grid.Column="0"
            VerticalAlignment="Center"
            Content="Add Character"
            FontWeight="Bold" />
        <ScrollViewer
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            HorizontalScrollBarVisibility="Hidden"
            VerticalScrollBarVisibility="Auto">
            <Grid x:Name="CharacterContent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="45" />
                </Grid.RowDefinitions>
                <Label
                    x:Name="LblCharacterName"
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Content="Name"
                    FontWeight="Bold" />
                <Label
                    x:Name="LblCharacterTag"
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Content="Tag"
                    FontWeight="Bold" />
                <Label
                    x:Name="LblCharacterColor"
                    Grid.Row="0"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Content="Color"
                    FontWeight="Bold" />
                <Label
                    x:Name="LblCharacterDirectory"
                    Grid.Row="0"
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Content="Directory (Path)"
                    FontWeight="Bold" />
                <Label
                    x:Name="LblCharacterFileKey"
                    Grid.Row="0"
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    Content="File Location"
                    FontWeight="Bold" />

                <TextBox
                    x:Name="DynamicRow_0_Name"
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="5"
                    Padding="3"
                    Style="{StaticResource DefaultTextBox}"
                    Tag="Enter Character Name"
                    TextChanged="ShouldEnableSave" />
                <TextBox
                    x:Name="DynamicRow_0_Tag"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5"
                    Padding="3"
                    Style="{StaticResource DefaultTextBox}"
                    Tag="Enter Character Tag"
                    TextChanged="ShouldEnableSave" />
                <Button
                    x:Name="DynamicRow_0_Color"
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="5"
                    Padding="3"
                    Click="ColorButton_Click"
                    Content="#FF0000"
                    FontWeight="Bold"
                    Style="{StaticResource ColorButton}"
                    Tag="{Binding Text, ElementName=DynamicRow_0_Name}" />
                <TextBox
                    x:Name="DynamicRow_0_Path"
                    Grid.Row="1"
                    Grid.Column="3"
                    Margin="5"
                    Padding="3"
                    Style="{StaticResource DefaultTextBox}"
                    Tag="Path to Character Assets" />
                <ComboBox
                    x:Name="DynamicRow_0_FileKey"
                    Grid.Row="1"
                    Grid.Column="4"
                    Margin="5"
                    Padding="3"
                    ItemsSource="{Binding AvailableFiles}"
                    SelectedIndex="0"
                    Style="{StaticResource DefaultComboBox}"
                    Tag="{Binding AvailableFileTags}" />
            </Grid>
        </ScrollViewer>
        <Button
            x:Name="BtnAdd"
            Grid.Row="0"
            Grid.Column="2"
            Width="40"
            Margin="1,1,5,1"
            Padding="4,0,4,4"
            HorizontalAlignment="Right"
            Click="BtnAdd_Click"
            Content="+"
            FontSize="18"
            FontWeight="UltraBold"
            Style="{StaticResource DefaultButton}" />
        <Button
            x:Name="BtnSave"
            Grid.Row="2"
            Grid.Column="1"
            Click="BtnSave_Click"
            Content="Save &amp; Close"
            IsEnabled="{Binding SaveBtnShouldEnable}"
            Style="{StaticResource DefaultButton}" />
        <Button
            x:Name="BtnCancel"
            Grid.Row="2"
            Grid.Column="2"
            Click="BtnCancel_Click"
            Content="Cancel"
            Style="{StaticResource DefaultButton}" />
    </Grid>
</Window>
