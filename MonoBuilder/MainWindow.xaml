<Window
    x:Class="MonoBuilder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MonoBuilder"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MonoBuilder"
    Width="960"
    Height="575"
    MinWidth="900"
    MinHeight="400"
    Padding="25"
    Style="{StaticResource WindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <Style TargetType="Hyperlink">
            <Setter Property="TextDecorations" Value="None" />
            <Setter Property="Foreground" Value="#BB0000" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline" />
                    <Setter Property="Foreground" Value="#FF0000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid
        x:Name="MainGrid"
        MaxWidth="1250"
        Margin="25,25,25,25"
        RenderTransformOrigin="0.58,0.483">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform />
                <SkewTransform />
                <RotateTransform />
                <TranslateTransform />
            </TransformGroup>
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="320" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <StackPanel
                x:Name="Left_Panel"
                Grid.Column="0"
                Grid.ColumnSpan="1"
                Width="300"
                MinWidth="300"
                ScrollViewer.CanContentScroll="True">
                <Button
                    x:Name="BtnScriptBuilder"
                    Click="BtnScriptBuilder_Click"
                    Content="Script Builder"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnCharacterBuilder"
                    Content="Character Builder"
                    IsEnabled="False"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnImageBuilder"
                    Click="BtnImageBuilder_Click"
                    Content="Image Builder"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnSceneBuilder"
                    Click="BtnSceneBuilder_Click"
                    Content="Scene Builder"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnGalleryBuilder"
                    Click="BtnGalleryBuilder_Click"
                    Content="Gallery Builder"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnMediaBuilder"
                    Content="Media Builder"
                    IsEnabled="False"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnParticleBuilder"
                    Content="Particle Builder"
                    IsEnabled="False"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnMessageBuilder"
                    Content="Message Builder"
                    IsEnabled="False"
                    Style="{StaticResource DefaultButton}" />
                <Button
                    x:Name="BtnNotificationBuilder"
                    Content="Notification Builder"
                    IsEnabled="False"
                    Style="{StaticResource DefaultButton}" />
            </StackPanel>
        </ScrollViewer>
        <StackPanel
            x:Name="Middle_Panel"
            Grid.Column="1"
            Width="320"
            HorizontalAlignment="Center">
            <Button
                x:Name="SettingsButton"
                Width="90"
                Height="90"
                Padding="5"
                Click="SettingsButton_Click"
                Style="{StaticResource DefaultButton}">
                <Image
                    Width="70"
                    Height="70"
                    Source="Assets/Cog.png" />
            </Button>
            <Label
                x:Name="SettingsText"
                HorizontalAlignment="Center"
                Content="Settings"
                Visibility="{Binding ElementName=SettingsButton, Path=IsMouseOver, Converter={StaticResource BoolToVis}}" />
            <Button
                x:Name="ExitButton"
                Width="90"
                Height="90"
                Padding="5"
                Click="ExitButton_Click"
                Style="{StaticResource DefaultButton}">
                <Image
                    Width="70"
                    Height="70"
                    Source="Assets/Door.png" />
            </Button>
            <Label
                x:Name="ExitText"
                HorizontalAlignment="Center"
                Content="Exit"
                Visibility="{Binding ElementName=ExitButton, Path=IsMouseOver, Converter={StaticResource BoolToVis}}" />
        </StackPanel>
        <Grid
            x:Name="Right_Panel"
            Grid.Column="2"
            Grid.ColumnSpan="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="25" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Row="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                <Hyperlink
                    x:Name="VersionInfo"
                    Click="VersionInfo_Clicked"
                    FontWeight="Bold">
                    Version Information
                </Hyperlink>
            </TextBlock>
            <Image
                Grid.Row="1"
                Grid.Column="0"
                Source="Assets/Zone Master Productions Logo.png" />
            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                MinWidth="100"
                MinHeight="250"
                HorizontalAlignment="Center">
                <Hyperlink
                    x:Name="ImageLink"
                    NavigateUri="https://store.steampowered.com/app/1977000/Symbiotic_Invasion/"
                    RequestNavigate="Hyperlink_RequestNavigate">
                    <Grid>
                        <Image
                            MinWidth="100"
                            MinHeight="250"
                            Source="Assets/Symbiotic_Cover2.jpg"
                            Stretch="Uniform" />
                        <Rectangle
                            Grid.Row="2"
                            Grid.Column="0"
                            MinWidth="100"
                            MinHeight="250"
                            Fill="Black"
                            Opacity="0.25">
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=TextBlock}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                    </Grid>
                </Hyperlink>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
